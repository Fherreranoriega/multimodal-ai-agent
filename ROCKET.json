        "jsCode": "const items = $input.all();\nconst updatedItems = items.map((item) => {\n  const file_path = item?.json?.result?.file_path;\n  const publicUrl = `https://api.telegram.org/file/bot7873292058:AAH7TiqizzSLpTY-g1O-Do-ycOkhKb3Q0Rs/${file_path}`;\n  if (publicUrl.endsWith(\"undefined\")) {\n    // Add a comment to explain that the URL is not valid\n    // This is just a placeholder, replace it with your own logic\n    item.json.error = \"Invalid URL\";\n  } else {\n    item.json.publicUrl = publicUrl;\n  }\n  return item;\n});\n\nreturn updatedItems;\n"
